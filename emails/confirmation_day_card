<table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#1a2035;border:1px solid #242d42;border-radius:12px;margin-bottom:14px;">
  <tr><td style="padding:18px 20px;">
    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:12px;">
      <tr>
        <td>
          <div style="font-family:'Bebas Neue',Arial,sans-serif;font-size:20px;color:#ffffff;letter-spacing:1px;">[[date_label]]</div>
          <div style="font-size:12px;color:#4a5568;margin-top:2px;">[[session_start_formatted]] &rarr; [[session_end_formatted]] &middot; [[duration_hours]]h</div>
        </td>
        <td align="right" style="vertical-align:top;">
          <span style="background:rgba(93,240,160,0.12);border:1px solid rgba(93,240,160,0.3);border-radius:20px;padding:5px 12px;font-size:12px;font-weight:600;color:#5df0a0;white-space:nowrap;">[[rating]]</span>
        </td>
      </tr>
    </table>
    <table cellpadding="0" cellspacing="0" border="0" style="margin-bottom:14px;">
      <tr>
        <td style="background:#111827;border-radius:8px;padding:8px 14px;">
          <span style="font-size:13px;font-weight:600;color:#5dd4f0;">&#128168; [[wind_peak_kn]] kts peak</span>
        </td>
      </tr>
    </table>
    <div style="font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:#4a5568;margin-bottom:8px;">You'll be notified</div>
    <div style="margin-bottom:12px;">[[reminders_html]]</div>
    <div style="margin-top:4px;">
      <a href="[[day_app_link]]" style="font-size:12px;font-weight:600;color:#5dd4f0;text-decoration:none;">View forecast &rarr;</a>
      <span style="font-size:12px;color:#2a3347;margin:0 8px;">&#183;</span>
      <a href="[[day_app_link]]" style="font-size:12px;font-weight:600;color:#4a5568;text-decoration:none;">Remove notification</a>
    </div>
  </td></tr>
</table>
